{
  "info": {
    "name": "KidWatch2 Guardian API",
    "description": "Postman collection aligned with Sanctum authentication for Guardian endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Guardian Login",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": {
          "raw": "http://127.0.0.1:8000/api/v1/guardian/login",
          "protocol": "http",
          "host": ["127.0.0.1"],
          "port": "8000",
          "path": ["api", "v1", "guardian", "login"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"ischowalter@example.net\",\n  \"password\": \"Password123@\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "let data = pm.response.json();",
              "if (data.token) {",
              "  pm.environment.set(\"authToken\", data.token);",
              "  console.log('Token saved to environment: ' + data.token);",
              "} else {",
              "  console.warn('No token returned from login');",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Guardian Logout",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{authToken}}" }
        ],
        "url": {
          "raw": "http://127.0.0.1:8000/api/v1/guardian/logout",
          "protocol": "http",
          "host": ["127.0.0.1"],
          "port": "8000",
          "path": ["api", "v1", "guardian", "logout"]
        }
      }
    },
    {
      "name": "Guardian Logout All",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{authToken}}" }
        ],
        "url": {
          "raw": "http://127.0.0.1:8000/api/v1/guardian/logout-all",
          "protocol": "http",
          "host": ["127.0.0.1"],
          "port": "8000",
          "path": ["api", "v1", "guardian", "logout-all"]
        }
      }
    },
    {
      "name": "Guardian Profile",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{authToken}}" }
        ],
        "url": {
          "raw": "http://127.0.0.1:8000/api/v1/guardian/profile",
          "protocol": "http",
          "host": ["127.0.0.1"],
          "port": "8000",
          "path": ["api", "v1", "guardian", "profile"]
        }
      }
    },
    {
      "name": "Guardian Students",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{authToken}}" }
        ],
        "url": {
          "raw": "http://127.0.0.1:8000/api/v1/guardian/students",
          "protocol": "http",
          "host": ["127.0.0.1"],
          "port": "8000",
          "path": ["api", "v1", "guardian", "students"]
        }
      }
    },
    {
      "name": "Guardian Student Details",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{authToken}}" }
        ],
        "url": {
          "raw": "http://127.0.0.1:8000/api/v1/guardian/students/10",
          "protocol": "http",
          "host": ["127.0.0.1"],
          "port": "8000",
          "path": ["api", "v1", "guardian", "students", "10"]
        }
      }
    }
  ]
}
